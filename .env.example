# ============================================================
# Genoma Dashboard — Environment Variables Template
#
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit real secrets.
# ============================================================


# ── LLM Provider Keys (at least one required for evolution) ─────────

# Anthropic Claude — used when no higher-priority provider is set
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenRouter — takes priority over Anthropic when set
# Models: anthropic/claude-sonnet-4, openai/gpt-4o, etc.
OPENROUTER_API_KEY=your-openrouter-key

# OpenCode — highest-priority cloud provider when set
# Defaults to model: deepseek-v4-flash:free
OPENCODE_API_KEY=your-opencode-key

# Nous Research API — used when OpenRouter is not set
NOUS_API_KEY=your-nous-key

# OpenAI — used as API key for Ollama local when OPENAI_BASE_URL points to Ollama
OPENAI_API_KEY=your-openai-key


# ── Ollama (local inference) ─────────────────────────────────────────

# Base URL for a local Ollama instance (include /v1 or it is appended automatically)
# When Ollama is reachable at localhost:11434, it is preferred over all cloud keys
OLLAMA_API_BASE=http://localhost:11434/v1

# Override the base URL used by the OpenAI-compatible client
# Set this to an Ollama URL to force local inference
# OPENAI_BASE_URL=http://localhost:11434/v1


# ── Model selection ──────────────────────────────────────────────────

# Override the model used by sdd_evolve.py (applies to all providers)
# Examples: gemma4:31b-cloud (Ollama), anthropic/claude-sonnet-4 (OpenRouter)
# SDD_EVOLVE_MODEL=gemma4:31b-cloud

# Ollama-specific model override (used when Ollama is the active provider)
# SDD_OLLAMA_MODEL=gemma4:31b-cloud


# ── Paths ────────────────────────────────────────────────────────────

# Path to the hermes-agent repository
# Default: ~/.hermes/hermes-agent
HERMES_AGENT_REPO=~/.hermes/hermes-agent

# Path to the hermes-agent-self-evolution repository
# Default: sibling directory ../hermes-agent-self-evolution, falls back to ~/.hermes/hermes-agent-self-evolution
# EVOLUTION_DIR=~/.hermes/hermes-agent-self-evolution

# Python executable override — use when dspy/openai packages live in a specific venv
# Default: auto-detected (prefers python3.12 with dspy installed)
# PYTHON=/usr/bin/python3


# ── Frontend ─────────────────────────────────────────────────────────

# FastAPI backend URL consumed by the Next.js frontend
# Default: http://localhost:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
